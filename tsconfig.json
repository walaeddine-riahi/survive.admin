{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",                       // 🔹 Ajouté
    "paths": {
      "@/*": ["src/*"]                   // 🔹 Ajouté
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["prisma/**/*", ".next/types/**/*.ts", "src/**/*", "src/types/**/*.d.ts"],
  "exclude": ["node_modules"],
  "typeRoots": ["./node_modules/@types", "./src/types"]
}
