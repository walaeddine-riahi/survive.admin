"use client";

import {
  InjectionForm,
  type InjectionFormValues,
  InjectionTypeEnum,
  type SimulationOption,
  InjectionTriggerTypeEnum,
} from "@/components/injection-form";
import { useQuery } from "@tanstack/react-query";
import { Button } from "@/components/ui/button";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuTrigger,
} from "@/components/ui/dropdown-menu";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import { useToast } from "@/components/ui/use-toast";
import { Edit, MoreHorizontal, Plus, Trash2 } from "lucide-react";
import { useEffect, useState } from "react";

interface Injection {
  id: string;
  title: string;
  content: string | null;
  triggerType: string;
  timeOffset: number | null;
  isRepeating: boolean;
  repeatInterval: number | null;
  scenarioId: string;
  simulationId: string;
  acknowledged: boolean;
  isActive: boolean;
  type: string;
  imageUrl: string | null;
  videoUrl: string | null;
  payload: any;
  attachments: any;
  createdAt: string;
  updatedAt: string;
  scenario?: {
    id: string;
    name: string;
    simulationId: string;
  };
  simulation?: {
    id: string;
    title: string;
  };
}

export default function InjectionsPage() {
  const [injections, setInjections] = useState<Injection[]>([]);
  const [error, setError] = useState<string | null>(null);
  const [loading, setLoading] = useState(true);
  const [scenarios, setScenarios] = useState<Array<{ id: string; name: string; simulationId: string }>>([]);
  const [simulations, setSimulations] = useState<SimulationOption[]>([]);
  const [isFormOpen, setIsFormOpen] = useState(false);
  const [selectedInjection, setSelectedInjection] = useState<Injection | null>(
    null
  );
  const { toast } = useToast();

  // Charger les simulations et scénarios
  useQuery({
    queryKey: ['simulations'],
    queryFn: async () => {
      const res = await fetch('/api/simulations');
      if (!res.ok) throw new Error('Erreur lors du chargement des simulations');
      const data = await res.json();
      setSimulations(data.map((sim: any) => ({ id: sim.id, name: sim.name })));
      return data;
    },
  });

  useQuery({
    queryKey: ['scenarios'],
    queryFn: async () => {
      const res = await fetch('/api/scenarios');
      if (!res.ok) throw new Error('Erreur lors du chargement des scénarios');
      const data = await res.json();
      setScenarios(data.map((scenario: any) => ({
        id: scenario.id,
        name: scenario.name,
        simulationId: scenario.simulationId
      })));
      return data;
    },
  });

  const fetchInjections = async () => {
    try {
      // Inclure les relations scenario et simulation
      const response = await fetch("/api/injections?include=scenario,simulation");
      if (!response.ok) {
        throw new Error("Échec du chargement des injections");
      }
      const data: Injection[] = await response.json();
      
      // S'assurer que les données sont correctement formatées
      const formattedData = data.map(injection => ({
        ...injection,
        // Convertir les champs JSON en chaînes pour le formulaire
        payload: injection.payload ? JSON.stringify(injection.payload, null, 2) : '',
        attachments: injection.attachments ? JSON.stringify(injection.attachments, null, 2) : ''
      }));
      
      setInjections(formattedData);
    } catch (err) {
      console.error("Erreur lors du chargement des injections:", err);
      setError(err instanceof Error ? err.message : "Une erreur est survenue");
      toast({
        title: "Erreur",
        description: "Impossible de charger les injections",
        variant: "destructive",
      });
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchInjections();
  }, []);

  // Gestion de la création d'une injection
  const handleCreateInjection = async (data: InjectionFormValues) => {
    try {
      const response = await fetch('/api/injections', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          ...data,
          // Assurez-vous que les champs optionnels sont correctement gérés
          payload: data.payload ? JSON.parse(data.payload as string) : null,
          attachments: data.attachments ? JSON.parse(data.attachments as string) : null,
        }),
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.message || 'Erreur lors de la création de l\'injection');
      }

      toast({
        title: 'Succès',
        description: 'L\'injection a été créée avec succès',
      });

      setIsFormOpen(false);
      fetchInjections(); // Rafraîchir la liste
    } catch (error) {
      console.error('Erreur lors de la création de l\'injection:', error);
      toast({
        title: 'Erreur',
        description: error instanceof Error ? error.message : 'Une erreur est survenue',
        variant: 'destructive',
      });
    }
  };

  const handleUpdateInjection = async (data: InjectionFormValues) => {
    if (!selectedInjection) return;
    
    try {
      const response = await fetch(`/api/injections/${selectedInjection.id}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          ...data,
          // Assurez-vous que les champs optionnels sont correctement gérés
          payload: data.payload ? JSON.parse(data.payload as string) : null,
          attachments: data.attachments ? JSON.parse(data.attachments as string) : null,
        }),
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.message || 'Erreur lors de la mise à jour de l\'injection');
      }

      toast({
        title: 'Succès',
        description: 'L\'injection a été mise à jour avec succès',
      });

      setIsFormOpen(false);
      setSelectedInjection(null);
      fetchInjections(); // Rafraîchir la liste
    } catch (error) {
      console.error('Erreur lors de la mise à jour de l\'injection:', error);
      toast({
        title: 'Erreur',
        description: error instanceof Error ? error.message : 'Une erreur est survenue',
        variant: 'destructive',
      });
    }
  };

  const handleDeleteInjection = async (injectionId: string) => {
    if (!confirm("Êtes-vous sûr de vouloir supprimer cette injection ?"))
      return;
    console.log("Delete injection", injectionId);
    // TODO: Implement API call to DELETE /api/injections/[injectionId]
    try {
      const response = await fetch(`/api/injections/${injectionId}`, {
        method: "DELETE",
      });

      if (!response.ok) {
        throw new Error("Failed to delete injection");
      }

      toast({
        title: "Injection supprimée",
        description: "L'injection a été supprimée avec succès.",
      });

      fetchInjections(); // Refresh list
    } catch (error) {
      console.error("Error deleting injection:", error);
      toast({
        title: "Erreur",
        description:
          "Une erreur est survenue lors de la suppression de l'injection.",
        variant: "destructive",
      });
    }
  };

  if (loading) {
    return <div>Chargement des injections...</div>;
  }

  if (error) {
    return <div>Erreur: {error}</div>;
  }

  return (
    <div className="container mx-auto py-10">
      <h1 className="text-3xl font-bold mb-6">Injections</h1>
      <Button
        onClick={() => {
          setSelectedInjection(null); // Clear selected injection for create
          setIsFormOpen(true);
        }}
      >
        <Plus className="mr-2 h-4 w-4" /> Ajouter une injection
      </Button>

      <div className="mt-6 border rounded-lg overflow-hidden">
        <div className="relative w-full overflow-auto">
          <Table>
            <TableHeader className="bg-muted/50">
              <TableRow>
                <TableHead className="min-w-[200px]">Nom</TableHead>
                <TableHead className="min-w-[200px]">Description</TableHead>
                <TableHead className="w-[120px]">Type</TableHead>
                <TableHead className="w-[150px]">Déclenchement</TableHead>
                <TableHead className="w-[120px]">Décalage</TableHead>
                <TableHead className="min-w-[180px]">Scénario</TableHead>
                <TableHead className="min-w-[180px]">Simulation</TableHead>
                <TableHead className="w-[140px]">Créé le</TableHead>
                <TableHead className="w-[140px]">Mis à jour</TableHead>
                <TableHead className="w-[80px] text-right">Actions</TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              {injections.map((injection) => {
                const triggerTypeMap: Record<string, string> = {
                  'MANUAL': 'Manuel',
                  'TIMED': 'Temporisé',
                  'DELAYED': 'Différé',
                  'EVENT': 'Événement',
                };
                
                return (
                  <TableRow key={injection.id} className="hover:bg-muted/50">
                    <TableCell className="font-medium py-3">
                      <div className="font-semibold">{injection.title}</div>
                      <div className="text-xs text-muted-foreground font-mono truncate max-w-[180px]" title={injection.id}>
                        {injection.id}
                      </div>
                    </TableCell>
                    <TableCell className="max-w-[200px] py-3">
                      <div className="line-clamp-2" title={injection.content || undefined}>
                        {injection.content || "-"}
                      </div>
                    </TableCell>
                    <TableCell className="py-3">
                      <span className="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary">
                        {injection.triggerType ? triggerTypeMap[injection.triggerType] || injection.triggerType : '-'}
                      </span>
                    </TableCell>
                    <TableCell className="py-3">
                      {injection.triggerType === 'TIMED' || injection.triggerType === 'DELAYED' ? (
                        <span className="font-mono bg-muted px-2 py-1 rounded">
                          {injection.timeOffset}s
                        </span>
                      ) : (
                        <span className="text-muted-foreground">-</span>
                      )}
                    </TableCell>
                    <TableCell className="py-3">
                      {injection.scenario?.name ? (
                        <div className="flex flex-col">
                          <span className="font-medium">{injection.scenario.name}</span>
                          <span className="text-xs text-muted-foreground font-mono truncate max-w-[160px]" title={injection.scenarioId}>
                            {injection.scenarioId}
                          </span>
                        </div>
                      ) : (
                        <span className="text-muted-foreground">-</span>
                      )}
                    </TableCell>
                    <TableCell className="py-3">
                      {injection.scenario?.simulationId ? (
                        <div className="flex flex-col">
                          <span className="font-medium">
                            {simulations.find(s => s.id === injection.scenario?.simulationId)?.name || injection.scenario.simulationId}
                          </span>
                          <span className="text-xs text-muted-foreground font-mono truncate max-w-[160px]">
                            {injection.scenario.simulationId}
                          </span>
                        </div>
                      ) : (
                        <span className="text-muted-foreground">-</span>
                      )}
                    </TableCell>
                    <TableCell className="whitespace-nowrap py-3">
                      <div className="text-sm">
                        {new Date(injection.createdAt).toLocaleDateString()}
                      </div>
                      <div className="text-xs text-muted-foreground">
                        {new Date(injection.createdAt).toLocaleTimeString()}
                      </div>
                    </TableCell>
                    <TableCell className="whitespace-nowrap py-3">
                      <div className="text-sm">
                        {new Date(injection.updatedAt).toLocaleDateString()}
                      </div>
                      <div className="text-xs text-muted-foreground">
                        {new Date(injection.updatedAt).toLocaleTimeString()}
                      </div>
                    </TableCell>
                    <TableCell className="py-3">
                      <div className="flex justify-end">
                        <DropdownMenu>
                          <DropdownMenuTrigger asChild>
                            <Button variant="ghost" className="h-8 w-8 p-0">
                              <MoreHorizontal className="h-4 w-4" />
                              <span className="sr-only">Ouvrir le menu</span>
                            </Button>
                          </DropdownMenuTrigger>
                          <DropdownMenuContent align="end">
                            <DropdownMenuItem
                              onClick={() => {
                                setSelectedInjection(injection);
                                setIsFormOpen(true);
                              }}
                            >
                              <Edit className="mr-2 h-4 w-4" />
                              Modifier
                            </DropdownMenuItem>
                            <DropdownMenuItem
                              className="text-destructive focus:text-destructive"
                              onClick={() => handleDeleteInjection(injection.id)}
                            >
                              <Trash2 className="mr-2 h-4 w-4" />
                              Supprimer
                            </DropdownMenuItem>
                          </DropdownMenuContent>
                        </DropdownMenu>
                      </div>
                    </TableCell>
                  </TableRow>
                );
              })}
            </TableBody>
            </Table>
          </div>
          {injections.length === 0 && (
            <div className="p-8 text-center text-muted-foreground">
              Aucune injection trouvée.
            </div>
          )}
        </div>

      <InjectionForm
        open={isFormOpen}
        onOpenChange={(open) => {
          setIsFormOpen(open);
          if (!open) setSelectedInjection(null);
        }}
        onSubmit={
          selectedInjection ? handleUpdateInjection : handleCreateInjection
        }
        scenarioId={selectedInjection?.scenarioId || ""}
        simulationId={selectedInjection?.scenario?.simulationId || ""}
        scenarios={scenarios}
        simulations={simulations}
        onSimulationChange={(simulationId) => {
          // Mettre à jour le formulaire avec la nouvelle simulation sélectionnée
          if (selectedInjection) {
            const updatedInjection = {
              ...selectedInjection,
              scenarioId: "", // Réinitialiser le scénario lors du changement de simulation
              scenario: {
                id: selectedInjection.scenario?.id || "",
                name: selectedInjection.scenario?.name || "",
                simulationId
              }
            };
            setSelectedInjection(updatedInjection as Injection);
          }
        }}
        initialData={
          selectedInjection
            ? {
                id: selectedInjection.id,
                title: selectedInjection.title,
                content: selectedInjection.content || "",
                triggerType: selectedInjection.triggerType as InjectionTriggerTypeEnum,
                timeOffset: selectedInjection.timeOffset,
                isRepeating: selectedInjection.isRepeating,
                repeatInterval: selectedInjection.repeatInterval,
                scenarioId: selectedInjection.scenarioId,
                simulationId: selectedInjection.scenario?.simulationId || "",
                isActive: selectedInjection.isActive,
                type: selectedInjection.type as InjectionTypeEnum || InjectionTypeEnum.OTHER,
                imageUrl: selectedInjection.imageUrl || "",
                videoUrl: selectedInjection.videoUrl || "",
                attachments: selectedInjection.attachments ? JSON.stringify(selectedInjection.attachments, null, 2) : "",
                payload: selectedInjection.payload ? (typeof selectedInjection.payload === 'string' 
                  ? selectedInjection.payload 
                  : JSON.stringify(selectedInjection.payload, null, 2)) 
                  : ""
              }
            : undefined
        }
      />
    </div>
  );
}