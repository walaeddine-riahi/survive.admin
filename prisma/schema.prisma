// =====================================
// BIA Reports Management
// =====================================

enum BiaReportFormat {
  PDF
  DOCX
  JSON
  HTML
}

enum BiaReportStatus {
  DRAFT
  GENERATED
  ARCHIVED
  SHARED
}

model BiaReport {
  id                  String           @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  description         String?
  format              BiaReportFormat
  status              BiaReportStatus  @default(GENERATED)
  
  // Métadonnées du rapport
  totalProcesses      Int              @default(0)
  continuityLevel     Int              @default(0) // Score de continuité (0-100)
  continuityLevelText String?          // Niveau textuel (Excellent, Bon, etc.)
  riskCount           Int              @default(0)
  recommendationCount Int              @default(0)
  
  // Contenu du rapport
  reportData          Json             // Données complètes du rapport
  content             String?          // Contenu textuel si applicable
  
  // Fichier
  fileName            String?
  filePath            String?          // Chemin du fichier sur le serveur
  fileSize            Int              @default(0) // Taille en bytes
  mimeType            String?
  
  // Paramètres de génération
  generationParams    Json?            // Paramètres utilisés pour générer le rapport
  includedProcessIds  String[]         // IDs des processus inclus dans le rapport
  
  // Partage et permissions
  isPublic            Boolean          @default(false)
  shareToken          String?          @unique // Token pour partage public
  expiresAt           DateTime?        // Date d'expiration du partage
  downloadCount       Int              @default(0)
  
  // Tags et catégorisation
  tags                String[]         @default([])
  category            String?          // Catégorie du rapport (mensuel, audit, etc.) - conservé pour rétrocompatibilité
  
  // Factory relation (nouveau)
  factoryId           String?          @db.ObjectId
  factory             Factory?         @relation("FactoryReports", fields: [factoryId], references: [id])
  
  // Relations
  authorId            String           @db.ObjectId
  author              User             @relation("AuthoredBiaReports", fields: [authorId], references: [id])
  
  // Métadonnées
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  
  @@map("bia_reports")
}
