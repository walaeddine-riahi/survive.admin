// Paramètres de continuité & méthodologie risque — par organisation/site
model ContinuitySettings {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  factoryId             String   @unique @db.ObjectId
  factory               Factory  @relation(fields: [factoryId], references: [id], onDelete: Cascade)

  // Seuils ISO 22301 personnalisables
  maxRtoHours           Int      @default(4)
  maxRpoHours           Int      @default(2)
  maxMtpdHours          Int      @default(72)
  minMbcoPercent        Int      @default(60)

  // Seuils d'alerte
  rtoWarningThreshold   Int      @default(8)
  rpoWarningThreshold   Int      @default(4)
  mtpdWarningThreshold  Int      @default(120)

  // Méthodologie de risque — 100% personnalisable
  riskMethodology       String   @default("ISO_31000")
  riskMethodologyLabel  String?

  // Matrice de risque configurable (JSON complet)
  // Structure: {
  //   axeX: { label: "Vraisemblance", levels: [{value:1,label:"Rare",...}] },
  //   axeY: { label: "Impact", levels: [{value:1,label:"Négligeable",...}] },
  //   thirdAxis: { enabled: bool, label: "Vitesse", levels: [...] } | null,
  //   formula: "X*Y" | "X*Y*Z" | "custom",
  //   thresholds: [{min:1,max:5,label:"Faible",color:"#16a34a"},{...},...],
  //   treatmentOptions: [{value:"REDUCE",label:"Réduire",...}]
  // }
  riskMatrixConfig      Json?

  // Standards de conformité applicables
  applicableStandards   String[] @default(["ISO 22301"])

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("continuity_settings")
}

